# jobjob APP config — one jobjob instance, machine-local.
#
# Setup:
#   cp config/.env.template config/.env
#   # then edit config/.env with your values
#
# config/.env is loaded at runtime (python-dotenv) and is gitignored — never
# commit real values. Only this template is committed. Plain KEY=value.
#
# This file holds ONLY app-instance settings: secrets, local paths, output IDs,
# and the profile registry. Applicant identity and the resume template live in
# the active PROFILE repo's config/.profile (committed there) — do not put them
# here (load-time validation rejects profile keys in the app config).

# --- Anthropic ---
ANTHROPIC_API_KEY=""
# CLAUDE_MODEL="claude-sonnet-4-6"        # optional; this is the default

# --- Response cache ---
# CLAUDE_CACHE_ENABLED="true"             # optional; set "false" to disable
# CACHE_DIR="~/.cache/jobjob"             # optional; local response-cache dir

# --- Google Drive/Docs (only needed without --skip-drive) ---
GOOGLE_CREDENTIALS_FILE="~/.config/jobjob/credentials.json"
GOOGLE_TOKEN_FILE="~/.config/jobjob/token.pickle"

# --- Applications (apply) input/output ---
# Input/working root holding jobs/, profiles/, and completed/. A processed JD is
# moved into <APPLICATIONS_INPUT_DIR>/completed/jobs/ on completion. Default "data".
APPLICATIONS_INPUT_DIR="data"
# Output: a Drive folder id and/or a local synced mirror of it. When the mirror is
# set, the completed-applications list is read from there (fast); otherwise it falls
# back to the Drive API. Set at least one to receive output.
APPLICATIONS_OUTPUT_DRIVE_ID=""
APPLICATIONS_OUTPUT_DIR=""

# --- Enrichment (enrich) input/output ---
# Input root for `jobjob enrich`. Leave blank to reuse APPLICATIONS_INPUT_DIR.
# ENRICHMENT_INPUT_DIR=""
# Contacts spreadsheet id (only needed for `jobjob enrich`).
ENRICHMENT_OUTPUT_SHEET_ID=""

# Deprecated pre-2.4 names are still read and auto-migrated to the above on launch:
#   DATA_DIR → APPLICATIONS_INPUT_DIR, APPLICATIONS_LOCAL_DIR → APPLICATIONS_OUTPUT_DIR,
#   APPLICATIONS_FOLDER_ID → APPLICATIONS_OUTPUT_DRIVE_ID,
#   LINKEDIN_SHEET_ID → ENRICHMENT_OUTPUT_SHEET_ID.

# --- Profile registry ---
# Register each profile repo by path, then name the active one. A profile is a
# separate git repo with content/, reference/, and config/.profile.
#   JOBJOB_PROFILE_<NAME>="/path/to/your/profile"
# The `jobjob-app` launcher scaffolds a local profile automatically; set these
# by hand only for manual/dev runs:
# JOBJOB_PROFILE_LOCAL="~/jobjob/profile"
# JOBJOB_ACTIVE_PROFILE="local"
