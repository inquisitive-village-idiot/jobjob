# jobjob example profile — the bundled Tila Mer demo persona (read-only).
#
# This makes static/ a complete, switchable profile: content/ + reference/ + this
# config. It is for reference only — to use it, duplicate it into a profile you own
# (Settings → Profiles → Duplicate), then edit your copy. The fields below are the
# fictional persona's; replace them in your own profile.
#
# RESUME_TEMPLATE_ID is intentionally blank — point it at your own Google Doc.
APPLICANT_NAME="Tila Mer"
APPLICANT_EMAIL="tila.mer@inkstained.news"
APPLICANT_PHONE="(312) 555-0148"
APPLICANT_LINKEDIN=""
RESUME_TEMPLATE_ID=""
# Optional domain hint so the resume objective describes the target company
# accurately for the field (blank = no hint).
INDUSTRY="science journalism"
